viviceramic/assets/fonts/node_modules/
viviceramic/hallowceramics-theme-auto-pages/assets/fonts/node_modules/

# Product and review images
viviceramic/images/products/*/
viviceramic/images/reviews/

# Playwright
.playwright-mcp/
*.log

# Python
__pycache__/
*.pyc
*.pyo
*.pyd

# macOS
__MACOSX/
.DS_Store
.AppleDouble
.LSOverride

# Temporary files
*.tmp
*.swp
*~

# Product and review images (negations must come before blocking patterns)
!viviceramic/images/products/*.png
!viviceramic/images/products/**/*.png
!viviceramic/images/reviews/*.png
!viviceramic/images/reviews/**/*.png

# Debug screenshots
*.png

# Claude Code settings (optional)
.claude/

# Windows thumbnails
Thumbs.db
