# Node
node_modules/
viviceramic/assets/fonts/node_modules/
viviceramic/hallowceramics-theme-auto-pages/assets/fonts/node_modules/

# Build / release artifacts (zip the theme folder locally when uploading to WordPress)
*.zip

# Env and secrets
.env
.env.*
!.env.example

# IDE / tooling (local only)
.cursor/
.idea/
*.code-workspace
.vscode/

# Playwright
.playwright-mcp/

# Logs
*.log
npm-debug.log*

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/

# macOS
__MACOSX/
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db

# Temporary files
*.tmp
*.swp
*~

# Claude Code (local settings; not for the remote repo)
.claude/

# Images — only track logo files needed by the theme and frontend
**/*.png
**/*.jpg
**/*.jpeg
**/*.webp
**/*.gif
**/*.svg
!viviceramic/hallowceramics-theme-auto-pages/assets/fonts/**/*.svg
# Re-include logos (frontend + theme)
!viviceramic/images/logo-icon.png
!viviceramic/images/logo-text.png
!viviceramic/hallowceramics-theme-auto-pages/assets/images/logo-icon.png
!viviceramic/hallowceramics-theme-auto-pages/assets/images/logo-text.png

# Videos — only track the homepage banner pumpkin and theme copy
**/*.webm
**/*.mp4
!pumpkin_alpha_new.webm
!viviceramic/hallowceramics-theme-auto-pages/assets/media/pumpkin_alpha.webm

# Product / review images (local only, upload to WP media library directly)
viviceramic/images/product_render/
viviceramic/images/products/
viviceramic/images/reviews/

# Orphan vivceramic/ directory (legacy copy, not part of the project)
vivceramic/
